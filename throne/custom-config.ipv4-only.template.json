      },
      {
        "type": "remote",
        "tag": "kinopub",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-kinopub.srs",
        "update_interval": "2h",
        "download_detour": "D"
      }
    ],
    "auto_detect_interface": true,
    "final": "D",
    "rules": [
      {
        "inbound": [
          "tun-in"
        ],
        "action": "sniff",
        "timeout": "500ms"
      },
      {
        "protocol": [
          "dns"
        ],
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "D"
      },
      {
        "rule_set": [
          "ads-all"
        ],
        "action": "route",
        "outbound": "B"
      },
      {
        "rule_set": [
          "manual-d"
        ],
        "action": "route",
        "outbound": "D"
      },
      {
        "rule_set": [
          "manual-a",
          "netflix"
        ],
        "action": "route",
        "outbound": "A"
      },
      {
        "rule_set": [
          "manual-t",
          "openai",
          "anthropic",
          "ai-not-cn",
          "youtube",
          "spotify",
          "facebook",
          "instagram",
          "whatsapp",
          "twitter",
          "telegram",
          "tiktok",
          "discord",
          "linkedin",
          "microsoft",
          "google",
          "wikimedia",
          "bbc",
          "cnn",
          "kinopub"
        ],
        "action": "route",
        "outbound": "T"
      }
    ]
  }
}
