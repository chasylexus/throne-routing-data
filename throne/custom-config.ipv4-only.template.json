{
  "log": {
    "level": "debug"
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090"
    }
  },
  "dns": {
    "servers": [
      {
        "type": "local",
        "tag": "local",
        "prefer_go": true
      },
      {
        "type": "https",
        "tag": "dns-t",
        "server": "1.1.1.1",
        "server_port": 443,
        "path": "/dns-query",
        "tls": {
          "enabled": true,
          "server_name": "cloudflare-dns.com"
        },
        "detour": "T"
      },
      {
        "type": "https",
        "tag": "dns-a",
        "server": "1.1.1.1",
        "server_port": 443,
        "path": "/dns-query",
        "tls": {
          "enabled": true,
          "server_name": "cloudflare-dns.com"
        },
        "detour": "A"
      }
    ],
    "rules": [
      {
        "rule_set": [
          "manual-d"
        ],
        "action": "route",
        "server": "local"
      },
      {
        "rule_set": [
          "manual-a",
          "netflix"
        ],
        "action": "route",
        "server": "dns-a"
      },
      {
        "rule_set": [
          "manual-t",
          "openai",
          "anthropic",
          "ai-not-cn",
          "youtube",
          "spotify",
          "facebook",
          "instagram",
          "whatsapp",
          "twitter",
          "telegram",
          "tiktok",
          "discord",
          "linkedin",
          "microsoft",
          "google",
          "wikimedia",
          "bbc",
          "cnn",
          "kinopub"
        ],
        "action": "route",
        "server": "dns-t"
      }
    ],
    "final": "local",
    "independent_cache": true,
    "strategy": "ipv4_only"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30"
      ],
      "auto_route": true,
      "route_exclude_address": [
        "169.254.0.0/16",
        "224.0.0.0/4",
        "255.255.255.255/32",
        "fe80::/10",
        "ff00::/8"
      ]
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "T",
      "server": "__T_HOST__",
      "server_port": 443,
      "uuid": "__T_UUID__",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp",
      "tls": {
        "enabled": true,
        "server_name": "__T_SNI__",
        "utls": {
          "enabled": true,
          "fingerprint": "__T_FINGERPRINT__"
        },
        "reality": {
          "enabled": true,
          "public_key": "__T_PBK__",
          "short_id": "__T_SID__"
        }
      }
    },
    {
      "type": "vless",
      "tag": "A",
      "server": "__A_HOST__",
      "server_port": 443,
      "uuid": "__A_UUID__",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp",
      "tls": {
        "enabled": true,
        "server_name": "__A_SNI__",
        "utls": {
          "enabled": true,
          "fingerprint": "__A_FINGERPRINT__"
        },
        "reality": {
          "enabled": true,
          "public_key": "__A_PBK__",
          "short_id": "__A_SID__"
        }
      }
    },
    {
      "type": "direct",
      "tag": "D"
    },
    {
      "type": "block",
      "tag": "B"
    }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "tag": "ads-all",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "update_interval": "2h",
        "download_detour": "D"
      },
      {
        "type": "remote",
        "tag": "manual-d",
        "format": "source",
        "url": "https://raw.githubusercontent.com/chasylexus/throne-routing-data/main/rule-set/manual-d.json",
        "update_interval": "2h",
        "download_detour": "D"
      },
      {
        "type": "remote",
        "tag": "manual-a",
        "format": "source",
        "url": "https://raw.githubusercontent.com/chasylexus/throne-routing-data/main/rule-set/manual-a.json",
        "update_interval": "2h",
        "download_detour": "D"
      },
      {
        "type": "remote",
        "tag": "netflix",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-netflix.srs",
        "update_interval": "2h",
