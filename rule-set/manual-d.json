{
  "version": 1,
  "rules": [
    {
      // 1. Exact domains only.
      // Use for a full hostname match like "api.example.com".
      "domain": [
        "captive.apple.com",
        "connectivitycheck.gstatic.com",
        "connectivity-check.ubuntu.com",
        "detectportal.firefox.com",
        "msftconnecttest.com",
        "www.msftconnecttest.com",
        "www.msftncsi.com",
        "dns.msftncsi.com",
        "nmcheck.gnome.org",
        "network-test.debian.org"
      ],

      // 2. Domain suffixes.
      // Use for a domain and all its subdomains like "example.com".
      "domain_suffix": [
        "wifee.app",
        "wifee.org"
      ],

      // 3. Domain keywords.
      // Use sparingly because this is a substring match.
      "domain_keyword": [],

      // 4. IPs and CIDRs.
      // Single IPs are allowed here too, for example "203.0.113.10".
      "ip_cidr": []
    }
  ]
}
